{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "cix3752i-LabelLoader",
    "version": "0.1.5"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "identifier": "com.cix3752i.label-loader",
      "targets": ["deb", "appimage", "dmg", "app", "nsis"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "面單貼標加載器",
        "width": 720,
        "height": 620,
        "minWidth": 560,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ]
  }
}
